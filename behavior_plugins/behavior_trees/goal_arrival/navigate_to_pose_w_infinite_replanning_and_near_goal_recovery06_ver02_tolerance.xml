<!--
  Two-phase navigation BT with near-goal recovery (ported from
  navigate_to_pose_w_infinite_replanning_and_near_goal_recovery_heading05_1.xml).

  PROBLEM this fixes:
    When the goal cell (or its surroundings within the planner tolerance) is
    occupied by a real obstacle, a tight ComputePathToPose to {goal} FAILS:
      "GridBased plugin failed to plan ... Failed to create plan with tolerance"
    The previous single-phase tree just looped forever (clear costmaps → wait →
    backup → retry the SAME blocked goal). No recovery is possible that way.

  SOLUTION — drive AS CLOSE AS POSSIBLE to the obstacle and stop:
    Phase 1 (FAR, > 1.0 m): normal infinite replanning + recovery.
    Phase 2 (NEAR, ≤ 1.0 m and still failing): instead of retrying the blocked
      goal, plan to {goal} with the LOOSE planner (GridBasedLoose, tolerance 2.0)
      to obtain an approach path that ends short of the blocked goal, then
      NearestFreePointOnPath snaps to the nearest SAFE free point near the goal
      ({near_goal}), and a tight plan to {near_goal} drives the robot right up to
      the obstacle. Whether the drive succeeds or fails, HeadingCorrection always
      runs as the final step to rotate in place to the exact goal yaw.

  REQUIRED planner config (planner_server params):
    planner_plugins: ["GridBased", "GridBasedLoose"]
    GridBasedLoose.tolerance: 2.0   ← MUST be looser than GridBased, otherwise the
                                       loose plan fails identically and the robot
                                       loops. (Both were 0.6 → this was the bug.)
-->
<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <!-- Fallback (NOT Sequence): Phase 1 FAILURE must HAND OFF to Phase 2,
         not abort the goal.
           - Phase 1 SUCCESS (goal reached) → Fallback SUCCESS, Phase 2 skipped.
           - Phase 1 FAILURE (near goal, blocked) → Phase 2 runs → drive to the
             nearest free point near the obstacle, then rotate to the goal yaw. -->
    <Fallback name="TwoPhaseNavigation">

      <!-- ═══════════════════════════════════════════════════════════════
           PHASE 1: Far-from-goal navigation + infinite replanning.
           Exits when:
             (a) navigation succeeds (goal reached), or
             (b) robot is within 1.0 m of goal and still failing (→ Phase 2), or
             (c) 100 far-recovery cycles are exhausted.
           ═══════════════════════════════════════════════════════════════ -->
      <RecoveryNode number_of_retries="5" name="Phase1-FarNavigation">

        <PipelineSequence name="NavigateWithReplanning">
          <ControllerSelector selected_controller="{selected_controller}"
                              default_controller="FollowPath"
                              topic_name="controller_selector"/>
          <PlannerSelector selected_planner="{selected_planner}"
                           default_planner="GridBased"
                           topic_name="planner_selector"/>
          <RateController hz="1.0">
            <RecoveryNode number_of_retries="1" name="ComputePathToPose">
              <ComputePathToPose goal="{goal}" path="{path}"
                                 planner_id="{selected_planner}"
                                 error_code_id="{compute_path_error_code}"/>
              <Sequence>
                <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}"/>
                <ClearEntireCostmap name="ClearGlobalCostmap-Context"
                                    service_name="global_costmap/clear_entirely_global_costmap"/>
              </Sequence>
            </RecoveryNode>
          </RateController>
          <RecoveryNode number_of_retries="1" name="FollowPath">
            <FollowPath path="{path}" controller_id="{selected_controller}" goal_checker_id="goal_checker"
                        error_code_id="{follow_path_error_code}"/>
            <Sequence>
              <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
              <ClearEntireCostmap name="ClearLocalCostmap-Context"
                                  service_name="local_costmap/clear_entirely_local_costmap"/>
            </Sequence>
          </RecoveryNode>
        </PipelineSequence>

        <!-- Distance-gated recovery branch:
             - When FAR (> 1.0 m): Inverter(ArePosesNear) SUCCESS → recovery runs
               → RecoveryNode retries Phase 1.
             - When NEAR (≤ 1.0 m): Inverter FAILS → FarGoalRecovery FAILS →
               Phase 1 RecoveryNode FAILS → outer Fallback hands off to Phase 2. -->
        <Sequence name="FarGoalRecovery">
          <GetCurrentPose current_pose="{current_pose}"/>
          <Inverter name="NotNearGoal">
            <ArePosesNear ref_pose="{current_pose}" target_pose="{goal}" tolerance="2.0"/>
          </Inverter>
          <Fallback>
            <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
            <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}"/>
          </Fallback>
          <ReactiveFallback name="RecoveryFallback">
            <GoalUpdated/>
            <RecoveryOncePerLocation min_distance="0.5" name="OncePerLocation">
              <SequenceWithMemory name="RecoveryActions">
                <ClearEntireCostmap name="ClearLocalCostmap-Subtree"
                                    service_name="local_costmap/clear_entirely_local_costmap"/>
                <ClearEntireCostmap name="ClearGlobalCostmap-Subtree"
                                    service_name="global_costmap/clear_entirely_global_costmap"/>
                <Wait wait_duration="1.0"/>
                <BackUp backup_dist="0.10" backup_speed="0.15"
                        error_code_id="{backup_code_id}"/>
              </SequenceWithMemory>
            </RecoveryOncePerLocation>
          </ReactiveFallback>
        </Sequence>

      </RecoveryNode>

      <!-- ═══════════════════════════════════════════════════════════════
           PHASE 2: Near-goal navigation — drive as close as possible, then align.
           Entered ONLY when Phase 1 failed within 1.0 m of the goal.
           (Also runs — and exits immediately SUCCESS — if Phase 1 succeeded,
            because the outer Fallback short-circuits on Phase 1 SUCCESS.)
           ═══════════════════════════════════════════════════════════════ -->
      <Sequence name="Phase2-NearGoalNavigation">

        <Fallback name="NearGoalDriveOrSkip">
          <PipelineSequence name="NearGoalNavigateWithReplanning">
            <ControllerSelector selected_controller="{selected_controller}"
                                default_controller="FollowPath"
                                topic_name="controller_selector"/>
            <PlannerSelector selected_planner="{selected_planner}"
                             default_planner="GridBased"
                             topic_name="planner_selector"/>
            <RateController hz="1.0">
              <RecoveryNode number_of_retries="2" name="ComputePathToPose-Near">
                <Fallback name="FrozenPathOrReplan-Near">
                  <!-- Reuse the last globally-valid {path} (captured while the goal
                       was still reachable) when the goal is UNCHANGED and that path
                       is still usable. Avoids destroying it with a doomed replan. -->
                  <ReactiveSequence name="ReuseFrozenPath-Near">
                    <Fallback name="EnsureFrozenCaptured">
                      <Sequence name="FrozenStillValid">
                        <Inverter>
                          <GlobalUpdatedGoal/>
                        </Inverter>
                        <IsGoalNearby path="{frozen_path}" proximity_threshold="5.0"
                                      max_robot_pose_search_dist="3.0"/>
                      </Sequence>
                      <SetBlackboard output_key="frozen_path" value="{path}"/>
                    </Fallback>
                    <TruncatePathLocal input_path="{frozen_path}" output_path="{near_path}"
                                       distance_forward="1.5" distance_backward="0.0"
                                       pose="{current_pose}"/>
                    <!-- GUARD: TruncatePathLocal returns SUCCESS even on an EMPTY
                         input. IsGoalNearby FAILS on an empty path, forcing the
                         Fallback to fall through to DriveToNearestFreePoint-Near
                         (instead of following an empty {near_path}). -->
                    <IsGoalNearby path="{near_path}" proximity_threshold="5.0"
                                  max_robot_pose_search_dist="3.0"/>
                  </ReactiveSequence>
                  <!-- No reusable frozen path, OR the goal cell is blocked/inflated.
                       Drive AS CLOSE AS POSSIBLE:
                         1. Plan to {goal} with the LOOSE planner (GridBasedLoose,
                            tolerance 2.0) to obtain an approach path that ends short
                            of the blocked goal.
                         2. NearestFreePointOnPath walks {loose_path} and returns the
                            nearest SAFE free point near the goal ({near_goal}),
                            preserving the goal's heading (reads live local costmap).
                         3. Plan to {near_goal} with the tight planner → {near_path},
                            which FollowPath drives up to the obstacle.
                       At 1 Hz this re-plans every second, so a transient obstacle
                       that leaves is rediscovered. If the goal is truly walled off
                       (no safe point within search_radius) this Sequence FAILS and
                       we fall through to HeadingCorrection (park + align). -->
                  <!-- BIG-OBSTACLE APPROACH (planner-independent first step):
                       NearestFreePointOnPath does NOT need a planned path — it
                       ray-marches the STRAIGHT robot->goal line on the costmap and
                       returns the safe point closest to the goal ({near_goal}).
                       It MUST run FIRST: when a big obstacle walls off the goal,
                       BOTH GridBased and GridBasedLoose fail to plan to {goal}
                       (no free cell within tolerance), returning an empty path. The
                       old order put ComputePathToPose({goal}) before this node, so
                       that failure aborted the Sequence and the approach point was
                       never computed — the robot just stalled ~2.4 m out. Now we
                       compute the free point WITHOUT the planner, then plan only to
                       {near_goal}, which lies in free space and so plans cleanly. -->
                  <Sequence name="DriveToNearestFreePoint-Near">
                    <NearestFreePointOnPath path="{near_path}" goal="{goal}"
                                            new_goal="{near_goal}"/>
                    <ComputePathToPose goal="{near_goal}" path="{near_path}"
                                       planner_id="{selected_planner}"
                                       error_code_id="{compute_path_error_code}"/>
                  </Sequence>
                </Fallback>

                <ClearEntireCostmap name="ClearGlobalCostmap-Near"
                                    service_name="global_costmap/clear_entirely_global_costmap"/>
              </RecoveryNode>
            </RateController>
            <RecoveryNode number_of_retries="1" name="FollowPath-Near">
              <FollowPath path="{near_path}" controller_id="{selected_controller}" goal_checker_id="goal_checker"
                          error_code_id="{follow_path_error_code}"/>
              <ClearEntireCostmap name="ClearLocalCostmap-Near"
                                  service_name="local_costmap/clear_entirely_local_costmap"/>
            </RecoveryNode>
          </PipelineSequence>
          <!-- Drive failed (goal walled off / collision / empty plan): absorb the
               failure so Phase 2 still proceeds to HeadingCorrection. The robot
               stays parked at its current (closest-reachable) pose. -->
          <AlwaysSuccess name="DriveFailedButProceed"/>
        </Fallback>

        <!-- ALWAYS run after the drive (success OR failure): precise in-place
             rotation to the EXACT goal yaw. If the robot is farther than
             goal_proximity from the goal, HeadingCorrection returns FAILURE →
             Phase 2 FAILS → goal aborts (robot was never actually near). -->
        <HeadingCorrection name="AlignToGoalYaw"
                           goal="{goal}"
                           yaw_goal_tolerance="0.07"
                           max_angular_speed="0.6"
                           min_angular_speed="0.15"
                           goal_proximity="2.5"
                           cmd_vel_topic="cmd_vel_nav"/>

      </Sequence>

    </Fallback>
  </BehaviorTree>
</root>
