<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="6" name="NavigateRecovery">
      <PipelineSequence name="NavigateWithReplanning">
        <!-- ── Controller + Planner + Inflation Mode Selection ─────────────
             Ticks every BT cycle.  SetCostmapInflationRadius caches the
             last written value internally and skips the service call when
             the value has not changed, so there is no per-tick overhead.
        ──────────────────────────────────────────────────────────────── -->
        <Fallback>

          <!-- NARROW PATH BRANCH: switch to RPP controller, reduce inflation to squeeze through tight gaps -->
          <Sequence>
            <NarrowPath/>
            <ControllerSelector
              selected_controller="{selected_controller}"
              default_controller="DWB"
              topic_name="controller_selector"/>
            <PlannerSelector
              selected_planner="{selected_planner}"
              default_planner="NarrowPlanner"
              topic_name="planner_selector"/>
            <SetCostmapInflationRadius
              service_name="local_costmap/local_costmap/set_parameters"
              inflation_radius="0.5"
              param_name="inflation_layer.inflation_radius"/>
            <SetCostmapInflationRadius
              service_name="global_costmap/global_costmap/set_parameters"
              inflation_radius="0.5"
              param_name="inflation_layer.inflation_radius"/>
          </Sequence>

          <!-- NORMAL BRANCH: FollowPath controller, restore full inflation (always succeeds as fallback) -->
          <Sequence>
            <ControllerSelector
              selected_controller="{selected_controller}"
              default_controller="MPPI"
              topic_name="controller_selector"/>
            <PlannerSelector
              selected_planner="{selected_planner}"
              default_planner="GridBased"
              topic_name="planner_selector"/>
            <SetCostmapInflationRadius
              service_name="local_costmap/local_costmap/set_parameters"
              inflation_radius="0.6"
              param_name="inflation_layer.inflation_radius"/>
            <SetCostmapInflationRadius
              service_name="global_costmap/global_costmap/set_parameters"
              inflation_radius="0.6"
              param_name="inflation_layer.inflation_radius"/>
          </Sequence>

        </Fallback>
        <RateController hz="1.0">
          <RecoveryNode number_of_retries="1" name="ComputePathToPose">
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="{selected_planner}" error_code_id="{compute_path_error_code}"/>
            <Sequence>
              <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}"/>
              <ClearEntireCostmap name="ClearGlobalCostmap-Context" service_name="global_costmap/clear_entirely_global_costmap"/>
            </Sequence>
          </RecoveryNode>
        </RateController>
        <RecoveryNode number_of_retries="1" name="FollowPath">
          <FollowPath path="{path}" controller_id="{selected_controller}" error_code_id="{follow_path_error_code}"/>
          <Sequence>
            <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
            <ClearEntireCostmap name="ClearLocalCostmap-Context" service_name="local_costmap/clear_entirely_local_costmap"/>
          </Sequence>
        </RecoveryNode>
      </PipelineSequence>
      <Sequence>
        <Fallback>
          <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
          <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}"/>
        </Fallback>
        <ReactiveFallback name="RecoveryFallback">
          <GoalUpdated/>
          <RoundRobin name="RecoveryActions">
            <Sequence name="ClearingActions">
              <ClearEntireCostmap name="ClearLocalCostmap-Subtree" service_name="local_costmap/clear_entirely_local_costmap"/>
              <ClearEntireCostmap name="ClearGlobalCostmap-Subtree" service_name="global_costmap/clear_entirely_global_costmap"/>
            </Sequence>
            <!-- <Spin spin_dist="1.57" error_code_id="{spin_error_code}"/> -->
            <Wait wait_duration="3.0"/>
            <!-- <BackUp backup_dist="0.10" backup_speed="0.15" error_code_id="{backup_code_id}"/> -->
          </RoundRobin>
        </ReactiveFallback>
      </Sequence>
    </RecoveryNode>
  </BehaviorTree>
</root>


<!-- ═══════════════════════════════════════════════════════════════════
     TREE STRUCTURE DIAGRAM
     ═══════════════════════════════════════════════════════════════════

  MainTree
  └── [RecoveryNode] NavigateRecovery (retries=6)
      ├── [PipelineSequence] NavigateWithReplanning
      │   ├── [Fallback] Controller + Planner + Inflation Mode Selection
      │   │   ├── [Sequence] NARROW PATH BRANCH
      │   │   │   ├── NarrowPath                                          ← condition check
      │   │   │   ├── ControllerSelector (default="RPP")
      │   │   │   ├── PlannerSelector (default="NarrowPlanner")
      │   │   │   ├── SetCostmapInflationRadius (local, r=0.35)
      │   │   │   └── SetCostmapInflationRadius (global, r=0.35)
      │   │   └── [Sequence] NORMAL BRANCH (fallback, always succeeds)
      │   │       ├── ControllerSelector (default="FollowPath")
      │   │       ├── PlannerSelector (default="GridBased")
      │   │       ├── SetCostmapInflationRadius (local, r=0.55)
      │   │       └── SetCostmapInflationRadius (global, r=0.55)
      │   ├── [RateController] hz=1.0
      │   │   └── [RecoveryNode] ComputePathToPose (retries=1)
      │   │       ├── ComputePathToPose
      │   │       └── [Sequence] recovery
      │   │           ├── WouldAPlannerRecoveryHelp
      │   │           └── ClearEntireCostmap (ClearGlobalCostmap-Context)
      │   └── [RecoveryNode] FollowPath (retries=1)
      │       ├── FollowPath
      │       └── [Sequence] recovery
      │           ├── WouldAControllerRecoveryHelp
      │           └── ClearEntireCostmap (ClearLocalCostmap-Context)
      └── [Sequence] Recovery Branch
          ├── [Fallback] check if recovery would help
          │   ├── WouldAControllerRecoveryHelp
          │   └── WouldAPlannerRecoveryHelp
          └── [ReactiveFallback] RecoveryFallback
              ├── GoalUpdated                                             ← preempt if new goal
              └── [RoundRobin] RecoveryActions
                  ├── [Sequence] ClearingActions
                  │   ├── ClearEntireCostmap (ClearLocalCostmap-Subtree)
                  │   └── ClearEntireCostmap (ClearGlobalCostmap-Subtree)
                  └── Wait (3.0s)

     ═══════════════════════════════════════════════════════════════════ -->